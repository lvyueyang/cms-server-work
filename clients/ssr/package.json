{
  "name": "@cms/ssr",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/node/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./pages": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./server": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./helpers": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/node/index.js"
    }
  },
  "scripts": {
    "dev": "rsbuild build --watch",
    "build": "rsbuild build && tsc -p ./tsconfig.types.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^25.6.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rsbuild/plugin-type-check": "^1.3.4",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^24.5.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14"
  }
}
